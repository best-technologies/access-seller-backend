generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Store {
  id             String         @id @default(cuid())
  first_name     String
  last_name      String
  description    String?
  email          String         @unique
  phone          String
  address        String
  logo           String?
  status         StoreStatus    @default(pending)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  cacId          String?        @unique
  utilityBillId  String?        @unique
  taxClearanceId String?        @unique
  categories     Category[]
  notifications  Notification[]
  orders         Order[]
  products       Product[]
  cac            Document?      @relation("CACDoc", fields: [cacId], references: [id])
  tax_clearance  Document?      @relation("TaxClearanceDoc", fields: [taxClearanceId], references: [id])
  utility_bill   Document?      @relation("UtilityBillDoc", fields: [utilityBillId], references: [id])
  users          User[]
  Depot          Depot[]
}

model Document {
  id                String @id @default(cuid())
  secure_url        String
  public_id         String
  storeCac          Store? @relation("CACDoc")
  storeTaxClearance Store? @relation("TaxClearanceDoc")
  storeUtilityBill  Store? @relation("UtilityBillDoc")
}

model User {
  id                          String                @id @default(cuid())
  store_id                    String?
  email                       String                @unique
  password                    String
  guest_password              String?
  first_name                  String
  last_name                   String
  phone_number                String?
  display_picture             String?
  address                     String?
  gender                      Gender                @default(other)
  role                        UserRole              @default(user)
  status                      UserStatus            @default(active)
  is_active                   Boolean               @default(true)
  level                       UserLevel             @default(bronze)
  otp                         String?               @default("")
  otp_expires_at              DateTime?
  is_email_verified           Boolean?              @default(false)
  is_otp_verified             Boolean?              @default(false)
  allowedPartialPayment       Float?                @default(0)
  referralPercentage          Float?
  referralPaymentCount        Int?
  isAffiliate                 Boolean               @default(false)
  affiliateStatus             AffiliateStatus       @default(not_affiliate)
  usertype                    String?               // e.g. warehouse-admin (set on onboard)
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  permissions                 String[]              @default([])
  Affiliate                   Affiliate?
  AffiliateLink               AffiliateLink[]
  banks                       Bank[]
  cart                        Cart?
  commissions                 Commission[]
  CommissionPayout            CommissionPayout[]
  commissionReferralsReceived CommissionReferral[]  @relation("CommissionReferralReferred")
  commissionReferralsMade     CommissionReferral[]  @relation("CommissionReferralReferrer")
  CommissionReferral          CommissionReferral[]
  orders                      Order[]
  referredBy                  Referral[]            @relation("Referred")
  referrals_made              Referral[]            @relation("Referrer")
  referralCode                ReferralCode?
  shippingAddresses           ShippingAddress[]
  store                       Store?                @relation(fields: [store_id], references: [id])
  wallet                      Wallet?
  withdrawalRequests          WithdrawalRequest[]
  userPermissions             UserPermission[]
  shippingInformation         ShippingInformation[]
  consignmentsReceived        Consignment[]
  auditLogs                   AuditLog[]
}

model Product {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  sellingPrice        Float
  stock               Int
  displayImages       Json?
  storeId             String?
  commission          String?
  BookFormat          BookFormat           @default(hardcover)
  isActive            Boolean              @default(true)
  status              String               @default("active")
  rated               String?
  isbn                String?              @unique
  publisher           String?
  author              String?
  pages               Int?
  publishedDate       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isFeatured          Boolean              @default(false)
  bookId              String?
  sku                 String?
  shortDescription    String?
  taxStatus           String?
  backorders          Boolean?
  soldIndividually    Boolean?
  weight              Float?
  length              Float?
  width               Float?
  height              Float?
  allowCustomerReview Boolean?
  purchaseNote        String?
  tags                String[]
  inStock             Boolean              @default(true)
  normalPrice         Float
  AffiliateLink       AffiliateLink[]
  cartItems           CartItem[]
  CommissionReferral  CommissionReferral[]
  orderItems          OrderItem[]
  store               Store?               @relation(fields: [storeId], references: [id])
  PromoCode           PromoCode[]
  referrals           Referral[]
  categories          Category[]           @relation("ProductCategories")
  formats             Format[]             @relation("ProductFormats")
  genres              Genre[]              @relation("ProductGenres")
  languages           Language[]           @relation("ProductLanguages")
}

model Category {
  id             String    @id @default(cuid())
  name           String
  description    String?
  storeId        String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdByName  String?
  createdByEmail String?
  store          Store     @relation(fields: [storeId], references: [id])
  products       Product[] @relation("ProductCategories")

  @@unique([name, storeId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id                       String                @id @default(cuid())
  orderId                  String?               @unique
  productid                String?
  userId                   String
  storeId                  String?
  total                    Float?
  total_amount             Float                 @default(0)
  shippingInfo             Json?
  shipmentStatus           ShipmentStatus?       @default(awaiting_payment)
  shippingAddressId        String?
  referralSlug             String?
  orderPaymentStatus       orderPaymentStatus?   @default(awaiting_payment)
  trackingNumber           String?
  withdrawalStatus         OrderWithdrawalStatus @default(none)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  referralCode             String?
  shipping                 Float?
  shippingCost             Float?                @default(0)
  promoCode                String?
  promoDiscountPercent     Float?
  promoDiscountAmount      Float?
  isPartialPayment         Boolean               @default(false)
  partialPayNow            Float?
  partialPayLater          Float?
  partialAllowedPercent    Int?
  partialSelectedPercent   Int?
  fullPayNow               Float?
  fullPayLater             Float?
  paystackReference        String?               @unique
  paystackAuthorizationUrl String?
  paystackAccessCode       String?
  bankDepositSlips         Json?
  orderStatus              OrderStatus?          @default(pending)
  orderPaymentMethod       OrderPaymentmethod?   @default(payment_gateway)
  commissions              Commission[]
  CommissionReferral       CommissionReferral[]
  shippingAddress          ShippingAddress?      @relation(fields: [shippingAddressId], references: [id])
  store                    Store?                @relation(fields: [storeId], references: [id])
  user                     User                  @relation(fields: [userId], references: [id])
  items                    OrderItem[]
  withdrawalRequests       WithdrawalRequest[]
  shippingInformation      ShippingInformation?
}

// Shipping information for orders
model ShippingInformation {
  id      String @id @default(cuid())
  orderId String @unique(map: "ShippingInformation_order_unique")
  order   Order  @relation(fields: [orderId], references: [id])

  // User reference
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Shipping method and tracking
  shippingMethod String // 'pickup-depot', 'pickup-park', 'doorstep'
  isPickup       Boolean @default(false)
  trackingNumber String?

  // Contact information
  fullName    String?
  phoneNumber String?
  email       String?

  // Address information (for doorstep delivery)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String? @default("Nigeria")
  postalCode   String?

  // Park pickup specific fields (for pickup-park)
  parkLocation String?
  pickupDate   DateTime?

  // Depot information (for pickup-depot)
  depotId String?
  depot   Depot?  @relation(fields: [depotId], references: [id])

  // Delivery instructions (for doorstep) null
  deliveryInstructions String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensure orderId is unique
  @@unique([orderId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  price      Float
  totalPrice Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String
  productId  String
  code       String   @unique
  status     String   @default("pending")
  isUsed     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id])
  referred   User     @relation("Referred", fields: [referredId], references: [id])
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id])
}

model Commission {
  id                   String              @id @default(cuid())
  userId               String
  orderId              String
  totalPurchaseAmount  Float
  commissionPercentage String
  amount               Float
  status               CommissionStatus    @default(pending)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  order                Order               @relation(fields: [orderId], references: [id])
  user                 User                @relation(fields: [userId], references: [id])
  withdrawalRequests   WithdrawalRequest[]
}

model Notification {
  id          String   @id @default(cuid())
  store_id    String
  title       String
  description String
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [store_id], references: [id])
}

model Genre {
  id             String    @id @default(cuid())
  name           String    @unique
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdByName  String?
  createdByEmail String?
  products       Product[] @relation("ProductGenres")
}

model Language {
  id             String    @id @default(cuid())
  name           String    @unique
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdByName  String?
  createdByEmail String?
  products       Product[] @relation("ProductLanguages")
}

model Format {
  id             String    @id @default(cuid())
  name           String    @unique
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdByName  String?
  createdByEmail String?
  products       Product[] @relation("ProductFormats")
}

model AgeRating {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdByName  String?
  createdByEmail String?
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  discountPercent Float
  isActive        Boolean  @default(true)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
}

model ReferralCode {
  id        String   @id @default(cuid())
  code      String   @unique
  url       String   @unique
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model ReferralSetting {
  id                   String   @id @default(cuid())
  referralPercentage   Float    @default(5)
  referralPaymentCount Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Affiliate {
  id               String          @id @default(cuid())
  userId           String          @unique
  userName         String
  userEmail        String
  status           AffiliateStatus @default(pending)
  requestedAt      DateTime        @default(now())
  category         String?
  reason           String?
  reviewedAt       DateTime?
  reviewedByName   String?
  reviewedByEmail  String?
  notes            String?
  ninImageUrl      String?
  ninImagePublicId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id])
}

model AffiliateLink {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  slug       String   @unique
  createdAt  DateTime @default(now())
  clicks     Int      @default(0)
  orders     Int      @default(0)
  commission Float    @default(0)
  status     String?  @default("active")
  product    Product  @relation(fields: [productId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model CommissionPayout {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  status      String    @default("pending")
  method      String
  reference   String    @unique
  requestedAt DateTime  @default(now())
  paidAt      DateTime?
  user        User      @relation(fields: [userId], references: [id])
}

model WithdrawalRequest {
  id                     String              @id @default(cuid())
  payoutId               String?             @unique
  userId                 String
  orderId                String?
  commissionId           String?
  buyerName              String?
  buyerEmail             String?
  totalPurchaseAmount    Float?
  commissionAmount       Float?
  withdrawal_amount      Float?
  commissionPercentage   String?
  payoutMethod           String
  bankId                 String?
  payoutStatus           WithdrawalStatus    @default(pending)
  reference              String              @unique
  requestedAt            DateTime            @default(now())
  processedAt            DateTime?
  processedBy            String?
  notes                  String?
  rejectionReason        String?
  createdAt              DateTime?           @default(now())
  updatedAt              DateTime?           @updatedAt
  commissionReferralId   String?
  availableBalanceAfter  Float?              @default(0)
  availableBalanceBefore Float?              @default(0)
  bank                   Bank?               @relation(fields: [bankId], references: [id])
  commission             Commission?         @relation(fields: [commissionId], references: [id])
  CommissionReferral     CommissionReferral? @relation(fields: [commissionReferralId], references: [id])
  order                  Order?              @relation(fields: [orderId], references: [id])
  user                   User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([payoutStatus])
}

model Bank {
  id                 String              @id @default(cuid())
  userId             String
  bankName           String
  bankCode           String
  accountNumber      String
  accountName        String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id])
  withdrawalRequests WithdrawalRequest[]

  @@index([userId])
}

model Wallet {
  id                           String   @id @default(cuid())
  userId                       String   @unique
  total_earned                 Float    @default(0)
  available_for_withdrawal     Float    @default(0)
  total_withdrawn              Float    @default(0)
  balance_before               Float    @default(0)
  balance_after                Float    @default(0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  withdrawal_awaiting_approval Float?   @default(0)
  commission_awaiting_approval Float?   @default(0)
  user                         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ShippingAddress {
  id           String   @id @default(cuid())
  userId       String?
  firstName    String
  lastName     String
  email        String
  phone        String
  state        String
  city         String
  houseAddress String
  address      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  user         User?    @relation(fields: [userId], references: [id])
}

model CommissionReferral {
  id                   String                    @id @default(cuid())
  userId               String
  orderId              String?
  referrerId           String?
  referredId           String?
  productId            String?
  type                 String?
  code                 String?                   @unique
  status               CommissionReferralStatus? @default(pending)
  isUsed               Boolean?                  @default(false)
  totalPurchaseAmount  Float?
  commissionPercentage String?
  amount               Float?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  order                Order?                    @relation(fields: [orderId], references: [id])
  product              Product?                  @relation(fields: [productId], references: [id])
  referred             User?                     @relation("CommissionReferralReferred", fields: [referredId], references: [id])
  referrer             User?                     @relation("CommissionReferralReferrer", fields: [referrerId], references: [id])
  user                 User                      @relation(fields: [userId], references: [id])
  withdrawalRequests   WithdrawalRequest[]

  @@index([userId])
  @@index([orderId])
  @@index([referrerId])
  @@index([referredId])
  @@index([productId])
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  displayName     String
  category        String
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userPermissions UserPermission[]
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  grantedBy    String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

enum StoreStatus {
  not_verified
  pending
  approved
  rejected
  suspended
  closed
  archived
}

enum UserRole {
  super_admin
  admin
  inventory_manager
  shipment_manager
  marketer
  user
}

enum UserLevel {
  bronze
  silver
  gold
  platinum
  vip
}

enum Percentage {
  PERCENT_100 @map("100")
  PERCENT_75  @map("75")
  PERCENT_50  @map("50")
  PERCENT_25  @map("25")
  PERCENT_0   @map("0")
}

enum UserStatus {
  active
  suspended
  inactive
}

enum OrderStatus {
  pending
  confirmed
  shipped
  in_transit
  delivered
  cancelled
}

enum CommissionStatus {
  pending
  paid
  reversed
  cancelled
}

enum Gender {
  male
  female
  other
}

enum BookCategory {
  education
  fiction
  non_fiction
  science
  technology
  business
  self_help
  biography
  history
  philosophy
  religion
  politics
  economics
  psychology
  health
  cooking
  travel
  sports
  arts
  literature
  poetry
  drama
  mystery
  thriller
  romance
  fantasy
  science_fiction
  horror
  western
  adventure
  humor
  comics
  graphic_novels
  children
  young_adult
  academic
  textbook
  reference
  dictionary
  encyclopedia
  magazine
  newspaper
  other
}

enum BookGenre {
  education
  fiction
  non_fiction
  mystery
  romance
  fantasy
  science_fiction
  horror
  biography
  self_help
  other
}

enum BookLanguage {
  english
  spanish
  french
  german
  chinese
  japanese
}

enum BookFormat {
  audiobook
  e_book
  hardcover
  paperback
  hardcopy
}

enum AffiliateStatus {
  not_affiliate
  awaiting_approval
  pending
  approved
  rejected
  active
  inactive
}

enum WithdrawalStatus {
  not_requested
  pending
  paid
  cancelled
}

enum OrderWithdrawalStatus {
  none
  processing
  completed
  rejected
  failed
}

enum ShipmentStatus {
  awaiting_payment
  processing
  in_transit
  awaiting_verification
  delivered
  cancelled
  returned
  lost
  damaged
  other
}

enum orderPaymentStatus {
  awaiting_payment
  completed
  partial
  cancelled
  awaiting_verification
}

enum OrderPaymentmethod {
  paystack
  bank_deposit
  payment_gateway
}

enum CommissionReferralStatus {
  awaiting_approval
  pending
  approved
  rejected
}

model Depot {
  id                         String                @id @default(cuid())
  storeId                    String
  state                      String
  city                       String
  depot_officer_name         String
  depot_officer_email        String
  depot_officer_phone        String
  depo_officer_house_address String
  description                String?
  status                     DepotStatus           @default(active)
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  store                      Store                 @relation(fields: [storeId], references: [id])
  shippingInformations       ShippingInformation[]
}

enum DepotStatus {
  active
  inactive
  pending
  rejected
}

// ============ ELECTRONICS WAREHOUSE & DISTRIBUTION ============

enum ConsignmentStatus {
  pending    // Expected / in transit
  received   // Arrived at warehouse
  inspected  // Quality check done
  available  // Ready for bulk buyers
  partial_out // Some items allocated
  closed     // Fully allocated / done
}

enum BulkOrderStatus {
  pending
  confirmed
  packing
  completed
  cancelled
}

enum BulkOrderPaymentStatus {
  pending
  partial
  paid
}

model Consignment {
  id                String            @id @default(cuid())
  referenceNumber   String            @unique
  supplierName      String            // Manufacturer name
  supplierReference String?

  // Sales person
  salesPersonName   String?
  salesPersonPhone  String?
  salesPersonEmail  String?

  // Invoice & delivery
  invoiceNumber     String?           @unique
  deliveryNote      String?
  deliveryDate      DateTime?
  deliveryTime      String?           // "HH:mm" format

  // Payment terms
  paymentModeTerms  String?

  // Optional references
  manufacturerOrderNumber  String?
  dispatchDocumentNumber   String?

  // Overall totals (from items)
  overallTotalCartons  Int?            @default(0)
  overallTotalQuantity Int?            @default(0)
  overallTotalCost     Float?          @default(0)

  // Bank account paid to (manufacturer)
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?

  // Payment
  totalPaid         Float?            @default(0)
  balanceToPay      Float?            @default(0)

  // Amount in words
  amountToPayInWords  String?
  amountPaidInWords   String?

  receivedAt        DateTime?
  status            ConsignmentStatus @default(pending)
  warehouseLocation String?
  notes             String?
  receivedById      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  receivedBy  User?                 @relation(fields: [receivedById], references: [id])
  items       ConsignmentItem[]
  documents   ConsignmentDocument[]
  stockMovements StockMovement[]
}

model ConsignmentItem {
  id            String      @id @default(cuid())
  consignmentId String
  productId     String?     // Link to DistributionProduct (select from catalog)
  productName   String?     // Product/item name (fallback when productId null)
  sku           String?     // Optional SKU
  description   String?     // Optional description
  brand         String?
  model         String?
  cartons       Int         @default(0)
  quantity      Int
  unit          String      @default("pieces")
  unitPrice     Float       @default(0)
  totalCost     Float       @default(0)  // quantity * unitPrice (or entered)
  unitCost      Float?      // Legacy alias
  condition     String?     @default("new")
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  consignment   Consignment         @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  product       DistributionProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  bulkOrderItems BulkOrderItem[]

  @@index([productId])
}

model ConsignmentDocument {
  id            String     @id @default(cuid())
  consignmentId String
  documentType  String     // invoice, packing_list, etc.
  secure_url    String
  public_id     String
  createdAt     DateTime   @default(now())

  consignment Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
}

model BulkOrder {
  id              String                 @id @default(cuid())
  referenceNumber String                 @unique
  buyerName       String
  buyerEmail      String?
  buyerPhone      String?
  buyerCompany    String?
  status          BulkOrderStatus        @default(pending)
  totalAmount     Float?                 // Sum of (quantity * unitPrice) per item
  amountPaid      Float?                 @default(0)
  paymentStatus   BulkOrderPaymentStatus? @default(pending)
  paymentMethod   String?                // bank_transfer, cash, etc.
  paidAt          DateTime?
  invoiceNumber   String?                @unique
  notes           String?
  createdById     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  items     BulkOrderItem[]
  documents BulkOrderDocument[]
  invoices  Invoice[]
}

model BulkOrderDocument {
  id           String   @id @default(cuid())
  bulkOrderId  String
  documentType String   // invoice, delivery_note, receipt, etc.
  secure_url   String
  public_id    String
  createdAt    DateTime @default(now())

  bulkOrder BulkOrder @relation(fields: [bulkOrderId], references: [id], onDelete: Cascade)
}

model BulkOrderItem {
  id                String   @id @default(cuid())
  bulkOrderId       String
  consignmentItemId String
  quantity          Int
  unitPrice         Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bulkOrder       BulkOrder       @relation(fields: [bulkOrderId], references: [id], onDelete: Cascade)
  consignmentItem ConsignmentItem @relation(fields: [consignmentItemId], references: [id], onDelete: Cascade)

  @@unique([bulkOrderId, consignmentItemId])
  @@index([bulkOrderId])
  @@index([consignmentItemId])
}

// ============ STOCK / PRODUCT (Distribution) ============
// Master product catalog - select from here when creating consignments.
// currentStock updates when: consignment received (+), invoice paid (-), manual adjust.

model DistributionProduct {
  id                String   @id @default(cuid())
  sku               String   @unique
  name              String
  description       String?
  brand             String?
  model             String?
  category          String?
  unit              String   @default("pieces")
  currentStock         Int      @default(0)
  costPrice            Float?
  normalSellingPrice   Float?   // Suggested/default selling price
  discountedSellingPrice Float? // Discounted selling price
  reorderLevel         Int?     // Alert when stock below this
  warehouseLocation String?
  images            Json?    // [{ secure_url, public_id }] from Cloudinary
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  consignmentItems ConsignmentItem[]
  invoiceItems     InvoiceItem[]
  stockMovements   StockMovement[]

  @@index([sku])
  @@index([name])
  @@index([category])
  @@index([isActive])
}

// Audit trail for stock changes (like wallet balance before/after in fintech).
enum StockMovementType {
  consignment_in    // Stock in when consignment marked received
  consignment_revert // Stock out when consignment status set back to pending
  invoice_out       // Stock out when invoice marked paid / payment recorded
  invoice_restore   // Stock restored when invoice unmarked as paid
  adjust            // Manual adjustment
}

model StockMovement {
  id              String            @id @default(cuid())
  productId       String
  movementType    StockMovementType
  quantityDelta   Int               // + for in, - for out
  stockBefore     Int
  stockAfter      Int
  consignmentId   String?
  consignmentItemId String?
  invoiceId       String?
  reason          String?           // Optional, e.g. for manual adjust
  createdAt       DateTime         @default(now())

  product       DistributionProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  consignment   Consignment?        @relation(fields: [consignmentId], references: [id], onDelete: SetNull)
  invoice       Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([consignmentId])
  @@index([invoiceId])
  @@index([createdAt])
}


// ============ INVOICE (Distribution) ============

enum InvoiceStatus {
  draft
  issued
  partial
  paid
  overdue
  cancelled
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String        @unique
  bulkOrderId        String?       // Optional link to bulk order
  customerName       String
  customerEmail      String?
  customerPhone      String?
  customerCompany    String?
  companyAddress     String?       // Seller/company address (e.g. 121/123, Obafemi Awolowo Way, Oke-Ado, Ibadan)
  companyPhone       String?       // Seller/company phone (e.g. 08038086862, 08174615808)
  issueDate          DateTime
  dueDate            DateTime?
  status             InvoiceStatus @default(draft)
  subtotal           Float         @default(0)
  taxAmount          Float?        @default(0)
  totalAmount        Float         @default(0)
  amountPaid         Float         @default(0)
  balanceDue         Float         @default(0)
  amountInWords      String?       // e.g. "One Hundred and Twenty-Five Thousand Naira Only"
  paymentTerms       String?
  notes              String?
  managerSignedBy    String?       // Manager name who signed
  managerSignedAt    DateTime?     // When manager signed
  customerSignedBy   String?       // Customer name who signed
  customerSignedAt   DateTime?     // When customer signed
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  bulkOrder BulkOrder?  @relation(fields: [bulkOrderId], references: [id], onDelete: SetNull)
  items     InvoiceItem[]
  payments  InvoicePayment[]
  stockMovements StockMovement[]

  @@index([invoiceNumber])
  @@index([status])
  @@index([issueDate])
  @@index([bulkOrderId])
}

model InvoicePayment {
  id             String    @id @default(cuid())
  invoiceId      String
  amount         Float
  paidAt         DateTime  @default(now())
  paymentMethod  String?   // bank_transfer, cash, cheque, pos, etc.
  reference      String?   // transaction ref, cheque no, etc.
  notes          String?
  receiptUrl     String?   // Cloudinary secure_url
  receiptPublicId String?  // For deletion/update
  recordedById   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String? // Link to DistributionProduct for stock deduction when paid
  description String
  quantity    Int
  unit        String  @default("pieces")
  unitPrice   Float
  totalAmount Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice  Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product  DistributionProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([productId])
}

// ============ AUDIT LOG ============

model AuditLog {
  id          String   @id @default(cuid())
  actionType  String   // login, logout, reset_password, create_consignment, update_consignment, etc.
  userId      String?
  userEmail   String?  // Denormalized for display even if user is deleted
  userName    String?  // first_name + last_name at time of action
  entityType  String?  // consignment, bulk_order, user, etc.
  entityId    String?
  description String?  // Human-readable summary
  metadata    Json?    // Extra context: ip, userAgent, old/new values, etc.
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actionType])
  @@index([entityType])
  @@index([createdAt])
}
